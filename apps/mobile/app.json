{
  "expo": {
    "name": "Hediyola",
    "slug": "hediyola",
    "scheme": "hediyola",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF8F4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hediyola.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Hediyola, mağazalarda barkod tarayarak ürün eklemeniz için kameranıza erişir."
      }
    },
    "android": {
      "package": "com.hediyola.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF8F4"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Hediyola, barkod taramak için kameranıza erişmek istiyor."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
